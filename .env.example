# =========================================================
# Docker Images (required)
# =========================================================
# Container images used by the simulation stack.
# These must exist locally or be pullable from a registry.

ARDUPILOT_IMAGE=dhdevspace/auto_mns:ardupilot-latest
AIRSIM_IMAGE=dhdevspace/auto_mns:tevv-airsim-condo-latest-ceilingless
ROS2_IMAGE=dhdevspace/auto_mns:tevv-airstack-ros2-x11-node-release
PX4_IMAGE=dhdevspace/auto_mns:px4-airsim-px4

# =========================================================
# Configuration Root (required)
# =========================================================
# Root directory containing runtime configs such as:
#   config/
#     mission/
#     evaluation/
#     scenario_controller.yaml

CONFIG_ROOT=./config


# =========================================================
# Local Planner Integration (optional)
# =========================================================
# Controls how the local planner is handled by launch.sh
#
# Possible modes:
#
#   disabled
#     Do not start a planner.
#
#   external
#     Planner is assumed to already be running outside this stack.
#
#   managed-script
#     launch.sh will enter LOCAL_PLANNER_DIR and run
#     LOCAL_PLANNER_START_CMD to start the planner.
#
#   managed-compose
#     launch.sh will run docker compose inside LOCAL_PLANNER_DIR
#     using LOCAL_PLANNER_COMPOSE_FILE.

LOCAL_PLANNER_MODE=external


# =========================================================
# Local Planner Script Mode (used if LOCAL_PLANNER_MODE=managed-script)
# =========================================================

# Directory containing the planner repository
LOCAL_PLANNER_DIR=/home/mnsdemo01/Downloads/super_planner/docker/TEVV_docker

# Command used to start the planner
LOCAL_PLANNER_START_CMD="./run.sh"

# Command used to stop the planner
LOCAL_PLANNER_STOP_CMD="make stop"


# =========================================================
# Local Planner Docker Compose Mode (used if LOCAL_PLANNER_MODE=managed-compose)
# =========================================================
# If the planner provides its own docker-compose stack,
# launch.sh can start it automatically.

LOCAL_PLANNER_COMPOSE_FILE=
LOCAL_PLANNER_PROFILE=